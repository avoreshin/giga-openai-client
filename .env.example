# Скопируйте в .env и подставьте свои значения:
#   cp .env.example .env

# --- обязательно для npm test / llm-test.ts ---
# Ключ авторизации GigaChat API (Basic для OAuth на официальном URL).
GIGACHAT_AI_TOKEN=

# --- опционально ---
# Базовый URL API (по умолчанию https://gigachat.devices.sberbank.ru/api/v1/)
# GIGACHAT_AI_URL=https://gigachat.devices.sberbank.ru/api/v1/

# Модель и текст запроса в тесте
# GIGACHAT_MODEL=GigaChat-2-Max
# GIGACHAT_PROMPT=Привет! Ответь одним словом.

# TLS: дополнительный корневой/корпоративный PEM (путь от корня проекта или абсолютный)
# GIGACHAT_TLS_CA_FILE=certs/corp-ca.pem

# TLS: только отладка — отключить проверку цепочки сертификатов (1 или true). Небезопасно.
# GIGACHAT_TLS_INSECURE=0

# Альтернатива CA: стандарт Node — один файл с доп. CA (абсолютный путь)
# NODE_EXTRA_CA_CERTS=/path/to/extra-ca.pem
